#Object-oriented programming
# Glossary:
# Classes - blueprint for objects: collection of attributes and methods, grouping variables and functions together
# Object - Instantiation of a class (version of a class that exist)
# Instantiation - when an object is created based off a class
# Attributes - Name for variables and similar inside a class
# Methods - name for all the functions/similar in a class
# Inheritance - taking on extra attributes of your parent classes
# Parent class/superclass - the class above you in the inheritance ladder
# Sub class/child class - the class below that inherits
# Encapsulation - hiding variables from the end user via getters and setters
# Public variables - Variables that can be accessed directly from outside of the class
# Private variables - Variables that cannot be accessed outside of the class directly
# Getters - Methods that return attributes in a class
# Setters - Methods that display arributes in a class
# Overriding - Using the same method name to do something different
# Polymorphism - Using the same method name to do different actions (when share the parent class)
# Composition - when classes have classes inside itself, rather than inheriting from it.

# Rule of thumb: Composition over inheritance unless one thing IS-A different thing

# One file main.py

#Basic class
class Animal():
    #Constructor method - the method that runs when instantiation happens
    def __init__(self, name, age):
        self.name = name
        self.age = age
    #A method
    def eat(self):
        print(f"{self.name} is eating!")
        
#Inherited class
class Cat(Animal):
    def __init__(self, name, age, claws):
        self.claws = claws
        #Calling the superclass to do its constructor
        super().__init__(name, age)
    #Function not from the base class
    def catch_mouse(self):
        print(f"{self.name} has caught a mouse!")
        
#Class that modifies attributes
class Counter():
    def __init__(self):
        self.count = 0
    def increase_by(self, num):
        self.count += num
    def decrease_by(self, num):
        self.count -= num
    def show(self):
        print(self.count)
        

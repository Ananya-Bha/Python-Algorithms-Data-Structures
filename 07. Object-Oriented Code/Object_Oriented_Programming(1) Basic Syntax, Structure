# Person class (abstract class)
# Private attributes - Name and age
# Methods - getters and setters for above, role (polymorphism based on the class)
# Two inheritance - Teacher and Student
# Headteacher inherits Teacher
# Teacher attributes - subject (getters and setters)
# Headteacher - office (getters and setters)
# Student - grade (getters and setters)


class Person():
    def __init__(self,name,age):
        self.__name=name
        self.__age=age
        
    def get_name(self):
        return self.__name
        
    def get_age(self):
        return self.__age
        
    def change_age(self,new_age):
        if new_age<0:
            print("Age cannot be below 0!")
            return False
        self.__age += new_age
        return True
        
    def change_name(self,new_name):
        if len(new_name)==0:
            print("No name has been entered!")
            return False
        self.__name=new_name
        return True
        
        
    def display_role(self):
        print("I am a person")


class Teacher(Person):
    def __init__(self, name, age, subject):
        self.__subject=subject
        super().__init__(name,age)
        
    def get_subject(self):
        return self.__subject
        
    def change_subject(self, new_subject):
        if len(new_subject)==0:
            print("No subject has been entered!")
            return False
        self.__subject=new_subject
        return True
    
    #Display the role for Teacher
    def display_role(self):
        print("I am a Teacher.")
    
    
class Student(Person):
    def __init__(self, name, age, grade):
        self.__grade=grade
        self.__grades = ["F", "D", "C", "B", "A", "A+"]
        super().__init__(name,age)
        
    # Output the grade in the letter format using the index of grades    
    def get_grade(self):
        return self.__grades[self.__grade]
        
    def increase_grade(self, grade_change):
        new_grade += grade_change
        if not(0 <= new_grade < len(self.__grades)):#Check if the new grade is in the appropriate range
            print("Grade not found!")
            return False
        self.__grade = new_grade
        return True
      
    #Display the role for student  
    def display_role(self):
        print("I am a Student.")
        

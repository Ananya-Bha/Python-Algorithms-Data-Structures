#Person.py-----------------------------------------------------#

class Person():
    def __init__(self,name,age):
        self.__name=name
        self.__age=age
        
    def get_name(self):
        return self.__name
        
    def get_age(self):
        return self.__age
        
    def change_age(self,new_age):
        if new_age<0:
            print("Age cannot be below 0!")
            return False
        self.__age += new_age
        return True
        
    def change_name(self,new_name):
        if len(new_name)==0:
            print("No name has been entered!")
            return False
        self.__name=new_name
        return True
        
        
    def display_role(self):
        print("I am a person")


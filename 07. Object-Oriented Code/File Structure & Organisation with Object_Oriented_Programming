#Function to describe the given temperature (given in Celsius)
def describe_temp(magnitude,unit):
    if unit.lower()=="c":
        if magnitude <=0:
            return "Very Cold"
        elif 0<magnitude<=20:
            return "warm"
        elif magnitude>20:
            return "hot"
        
    if unit.lower()=="f":
        if magnitude <=59:
            return "Very Cold"
        elif 59<magnitude<=80:
            return "warm"
        elif magnitude>80:
            return "hot"

#Function that returns a boolean of a weather warning (>45C, then return a weather warning)
def check_for_warning(magnitude,unit):
    if unit.lower()=="c":
        if magnitude>=45:
            return "Weather Warning! Very Hot!"
        
        
    if unit.lower()=="f":
        if magnitude>=100:
            return "Weather Warning! Very Hot"
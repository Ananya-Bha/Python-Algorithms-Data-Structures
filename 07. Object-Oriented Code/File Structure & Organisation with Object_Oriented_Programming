#Importing the class Person from person.py
from person import Person

class Teacher(Person):
    def __init__(self, name, age, subject):
        self.__subject=subject
        super().__init__(name,age)
        
    def get_subject(self):
        return self.__subject
        
    def change_subject(self, new_subject):
        if len(new_subject)==0:
            print("No subject has been entered!")
            return False
        self.__subject=new_subject
        return True
    
    #Display the role for Teacher
    def display_role(self):
        print("I am a Teacher.")

        
class Head_Teacher(Teacher):
    def __init__(self, name,age,subject,office):
        self.__office=office
        super().__init__(name,age,subject)
        
    def get_office(self):
        return self.__office
        
    def set_office(self,new_office):
        if len(new_office)==0:
            print("No office has been chosen!")
            return False
        self.__office=new_office
        return True
        
    #Display the role for Headteacher    
    def display_role(self):
        print("I am the Headteacher.")


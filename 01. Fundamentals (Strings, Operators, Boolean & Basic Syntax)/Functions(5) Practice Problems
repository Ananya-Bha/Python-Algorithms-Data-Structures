"""Create a number guessing game.
First, think of a number between 1 and 100.
Then, allow the player to guess a number between 1 and 100.
If they are too high, tell them they are too high. If they are too low, tell them they are too low.
Once they get it right, tell them they've won and end the game."""

import random as r
number= r.randint(1,101)
chances_left=10
print("Enter a number between 1 & 100.\n(You only have 10 guesses to figure out what the number is! Good Luck:)\n")
while True:
    try:
        user_guess= int(input("Your Guess:"))
        if user_guess>100 or user_guess<1:
            chances_left-=1
            print("Out of range! Try Again!")
        elif user_guess==number:
            print("Correct!")
            break
        elif user_guess>number:
            chances_left-=1
            print("Too High!")
        elif user_guess<number:
            chances_left-=1
            print("Too Low!")
    except ValueError:
        chances_left -= 1
        print("What in the world is that! Please give an integer!")
    
    if chances_left != 0:
        print(f"You have {chances_left} chances left to guess the number!")    
    else:
        print(f"You have run out of chances! The number was: {number}!")
        break
    

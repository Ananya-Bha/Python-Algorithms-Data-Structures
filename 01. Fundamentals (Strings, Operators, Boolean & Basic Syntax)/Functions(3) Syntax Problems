#Person B is older/younger/same age than person A

def compare_age(personA,personB):
    nameA= personA["name"]
    nameB= personB["name"]
    ageA= personA["age"]
    ageB= personB["age"]
    if ageB>ageA:
        return(nameB+" is older than "+nameA)
    elif ageA>ageB:
        return(nameA+" is older than "+nameB)
    else:
        return(nameA+" is the same age as "+nameB)
    
    
print(compare_age(p1,p2))

#Class version

class Person():
    def __init__(self, name, age): #Constructor
        self.name = name
        self.age = age
    def compare_age(self, personB):
        if personB.age > self.age:#Person B's age is bigger
            return f"{personB.name} is older than me"
        elif personB.age < self.age:#Our age is bigger
            return f"{personB.name} is younger than me"
        else:#We have the same age
            return f"{personB.name} is the same age as me"



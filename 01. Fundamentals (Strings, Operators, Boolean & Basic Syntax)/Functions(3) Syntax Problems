dct = {"cost_price": 32.67, "sell_price": 45.00, "inventory":100}

//dct["sell_price"] -> 45.0

def profit(dct):
    sell_p=dct["sell_price"]
    cost_p=dct["cost_price"]
    items=dct["inventory"]
    profit=((sell_p-cost_p)*items)
    return profit
    
 print(profit(dct))   

